<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:layout_marginLeft="10dp"
android:layout_marginTop="20dp"
android:layout_marginRight="10dp"
tools:context=".ForgotPassword">

<!-- Texto para recuperar contraseña -->

<LinearLayout
    android:id="@+id/linearSuperior"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvInformacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/san_francisco"
        android:gravity="center|center_horizontal"
        android:text="@string/fp_texto_recuperarcontra"
        android:textColor="@color/second_color"
        android:textSize="18dp" />
</LinearLayout>

<!-- Campo de correo -->

<LinearLayout
    android:id="@+id/linearCentral"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_below="@id/linearSuperior"
    android:layout_marginStart="10dp"
    android:layout_marginTop="20dp"
    android:layout_marginEnd="10dp"
    android:orientation="vertical">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilUsuarioCR"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/su_text_UsuarioR"
        app:startIconDrawable="@drawable/lg_ic_email">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtUsuarioCR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_medium"
            android:inputType="textEmailAddress"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>

<!-- Botón de recuperación -->

<LinearLayout
    android:id="@+id/linearInferior"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_below="@id/linearCentral"
    android:layout_marginTop="10dp"
    android:gravity="end"
    android:orientation="horizontal">

    <Button
        android:id="@+id/btnRecuperar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:drawableEnd="@drawable/su_ic_registro"
        android:drawableTint="#fff"
        android:fontFamily="@font/poppins_medium"
        android:text="@string/fp_btn_recuperar" />
</LinearLayout>
</RelativeLayout>